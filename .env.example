# PostgreSQL superuser (used by Docker Compose to initialize the DB)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=cheatsheets

# Application database user (created by init-db.sh with limited permissions)
APP_DB_USER=cheatsheets_app
APP_DB_PASSWORD=change_me_app

# Secret key for signing JWT tokens (change this in production!)
JWT_SECRET=change_me_jwt_secret

# Port for the Vite dev server (Docker Compose overrides this internally)
PORT=8080
